{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pov-lab.ru/schemas/template.schema.json",
  "title": "PoV Lab Task Template",
  "description": "Декларативное описание класса задач. См. specs/01_template_registry.md §2.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "type",
    "description",
    "owner",
    "status",
    "domain",
    "input_requirements",
    "output_contract",
    "escalation",
    "metadata"
  ],
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "composite" } } },
      "then": { "required": ["composite"], "not": { "anyOf": [{ "required": ["executable"] }, { "required": ["dynamic"] }] } }
    },
    {
      "if": { "properties": { "type": { "const": "executable" } } },
      "then": { "required": ["executable"], "not": { "anyOf": [{ "required": ["composite"] }, { "required": ["dynamic"] }] } }
    },
    {
      "if": { "properties": { "type": { "const": "dynamic" } } },
      "then": { "required": ["dynamic"], "not": { "anyOf": [{ "required": ["composite"] }, { "required": ["executable"] }] } }
    }
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{2,63}$"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "type": {
      "type": "string",
      "enum": ["composite", "executable", "dynamic"]
    },
    "description": { "type": "string", "minLength": 1, "maxLength": 500 },
    "owner": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["draft", "active", "deprecated"] },
    "domain": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,31}$" },
    "input_requirements": {
      "type": "array",
      "items": { "$ref": "#/$defs/InputRequirement" }
    },
    "output_contract": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/OutputArtifactSpec" }
    },
    "escalation": { "$ref": "#/$defs/EscalationPolicy" },
    "metadata": { "$ref": "#/$defs/TemplateMetadata" },
    "provenance": { "$ref": "#/$defs/Provenance" },
    "composite": { "$ref": "#/$defs/CompositeSpec" },
    "executable": { "$ref": "#/$defs/ExecutableSpec" },
    "dynamic": { "$ref": "#/$defs/DynamicSpec" }
  },
  "$defs": {
    "SchemaRef": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*:[a-z][a-z0-9_.]*@\\d+\\.\\d+\\.\\d+$"
    },
    "TemplateRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$" },
        "version": {
          "oneOf": [
            { "type": "string", "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$" },
            { "type": "string", "const": "latest" }
          ],
          "default": "latest"
        }
      }
    },
    "Provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor", "timestamp"],
      "properties": {
        "actor": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "reason": { "type": "string" },
        "correlation_id": { "type": "string", "format": "uuid" }
      }
    },
    "InputRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind", "artifact_type", "selector", "description"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
        "kind": { "type": "string", "enum": ["hard", "soft", "semantic"] },
        "artifact_type": { "type": "string", "minLength": 1 },
        "schema_ref": { "$ref": "#/$defs/SchemaRef" },
        "selector": { "$ref": "#/$defs/Selector" },
        "description": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "semantic" } } },
          "then": { "properties": { "selector": { "properties": { "kind": { "const": "semantic" } } } } }
        },
        {
          "if": { "properties": { "kind": { "enum": ["hard", "soft"] } } },
          "then": {
            "properties": {
              "selector": {
                "properties": {
                  "kind": { "enum": ["by_artifact_id", "by_producer", "by_type"] }
                }
              }
            }
          }
        }
      ]
    },
    "Selector": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "artifact_id"],
          "properties": {
            "kind": { "const": "by_artifact_id" },
            "artifact_id": { "type": "string", "format": "uuid" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "producer_template_id", "output_name"],
          "properties": {
            "kind": { "const": "by_producer" },
            "producer_template_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$" },
            "output_name": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "artifact_type"],
          "properties": {
            "kind": { "const": "by_type" },
            "artifact_type": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "query"],
          "properties": {
            "kind": { "const": "semantic" },
            "query": { "type": "string", "minLength": 1 },
            "k": { "type": "integer", "minimum": 1, "maximum": 50, "default": 5 },
            "filter": { "type": "object", "additionalProperties": { "type": "string" } }
          }
        }
      ]
    },
    "OutputArtifactSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "artifact_type", "mime_type", "description"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
        "artifact_type": { "type": "string" },
        "mime_type": { "type": "string", "pattern": "^[a-z]+/[a-zA-Z0-9.+_-]+$" },
        "schema_ref": { "$ref": "#/$defs/SchemaRef" },
        "description": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean", "default": true },
        "multiplicity": { "type": "string", "enum": ["one", "many"], "default": "one" }
      }
    },
    "EscalationPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_attempts": { "type": "integer", "minimum": 1, "maximum": 20, "default": 3 },
        "max_llm_calls": { "type": "integer", "minimum": 1, "maximum": 500, "default": 10 },
        "wall_clock_seconds": { "type": "integer", "minimum": 30, "maximum": 86400, "default": 1800 },
        "on_escalation": { "$ref": "#/$defs/TemplateRef" }
      }
    },
    "TemplateMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage_gate"],
      "properties": {
        "stage_gate": {
          "type": "string",
          "enum": ["intake", "requirements", "architecture", "implementation", "validation", "delivery"]
        },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "docs_url": { "type": "string", "format": "uri" },
        "since_version": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
        }
      }
    },
    "CompositeSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["children"],
      "properties": {
        "children": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/CompositeChildRef" }
        },
        "bubble_up_outputs": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/OutputBinding" }
        }
      }
    },
    "CompositeChildRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alias", "template_id"],
      "properties": {
        "alias": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
        "template_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$" },
        "template_version": {
          "oneOf": [
            { "type": "string", "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$" },
            { "type": "string", "const": "latest" }
          ],
          "default": "latest"
        },
        "depends_on": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
          "uniqueItems": true,
          "default": []
        },
        "input_bindings": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/InputBinding" }
        },
        "enabled_if": { "$ref": "#/$defs/Expression" }
      }
    },
    "InputBinding": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["from_alias", "output"],
          "properties": {
            "from_alias": { "type": "string" },
            "output": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["from_parent_input"],
          "properties": {
            "from_parent_input": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["literal"],
          "properties": {
            "literal": {}
          }
        }
      ]
    },
    "OutputBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from_alias", "output"],
      "properties": {
        "from_alias": { "type": "string" },
        "output": { "type": "string" }
      }
    },
    "Expression": {
      "type": "string",
      "minLength": 1,
      "description": "Безопасное boolean-выражение; грамматика описана в specs/01_template_registry.md §2.8"
    },
    "ExecutableSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["executor"],
      "properties": {
        "executor": { "type": "string", "enum": ["llm", "script", "hybrid"] },
        "llm": { "$ref": "#/$defs/LlmExecutorConfig" },
        "script": { "$ref": "#/$defs/ScriptExecutorConfig" }
      },
      "allOf": [
        {
          "if": { "properties": { "executor": { "const": "llm" } } },
          "then": { "required": ["llm"], "not": { "required": ["script"] } }
        },
        {
          "if": { "properties": { "executor": { "const": "script" } } },
          "then": { "required": ["script"], "not": { "required": ["llm"] } }
        },
        {
          "if": { "properties": { "executor": { "const": "hybrid" } } },
          "then": { "required": ["llm", "script"] }
        }
      ]
    },
    "LlmExecutorConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "prompt_ref", "token_budget"],
      "properties": {
        "model": { "type": "string", "pattern": "^[a-z0-9_-]+:[a-z0-9.-]+$" },
        "prompt_ref": { "$ref": "#/$defs/SchemaRef" },
        "tool_allowlist": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true,
          "default": []
        },
        "token_budget": { "$ref": "#/$defs/TokenBudget" },
        "temperature": { "type": "number", "minimum": 0, "maximum": 2, "default": 0.0 },
        "json_mode": { "type": "boolean", "default": false }
      }
    },
    "TokenBudget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_tokens_max", "output_tokens_max", "total_tokens_max"],
      "properties": {
        "input_tokens_max": { "type": "integer", "minimum": 512, "maximum": 2000000 },
        "output_tokens_max": { "type": "integer", "minimum": 128, "maximum": 200000 },
        "total_tokens_max": { "type": "integer", "minimum": 640, "maximum": 2200000 }
      }
    },
    "ScriptExecutorConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entrypoint", "timeout_seconds", "environment"],
      "properties": {
        "entrypoint": {
          "type": "string",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_.]*:[a-zA-Z_][a-zA-Z0-9_]*$"
        },
        "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 3600 },
        "environment": { "$ref": "#/$defs/EnvironmentRef" },
        "resources": { "$ref": "#/$defs/ResourceLimits" }
      }
    },
    "EnvironmentRef": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "image"],
          "properties": {
            "kind": { "const": "docker" },
            "image": { "type": "string" },
            "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "spec"],
          "properties": {
            "kind": { "const": "conda" },
            "spec": { "type": "string" }
          }
        }
      ]
    },
    "ResourceLimits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cpu": { "type": "string", "pattern": "^\\d+(\\.\\d+)?$", "default": "1" },
        "memory_mib": { "type": "integer", "minimum": 128, "default": 1024 },
        "gpu": { "type": "integer", "minimum": 0, "default": 0 }
      }
    },
    "DynamicSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision_executor", "max_depth", "max_children", "decomposition_rules", "fallback_template"],
      "properties": {
        "decision_executor": { "$ref": "#/$defs/LlmExecutorConfig" },
        "max_depth": { "type": "integer", "minimum": 1, "maximum": 5 },
        "max_children": { "type": "integer", "minimum": 1, "maximum": 20 },
        "decomposition_rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/DecompositionRule" }
        },
        "fallback_template": { "$ref": "#/$defs/TemplateRef" }
      }
    },
    "DecompositionRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["condition", "action"],
      "properties": {
        "condition": { "$ref": "#/$defs/Expression" },
        "action": { "type": "string", "enum": ["execute", "decompose"] },
        "child_templates": {
          "type": "array",
          "items": { "$ref": "#/$defs/TemplateRef" }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "action": { "const": "decompose" } } },
          "then": { "required": ["child_templates"], "properties": { "child_templates": { "minItems": 1 } } }
        }
      ]
    }
  }
}
