{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pov-lab.ru/schemas/task.schema.json",
  "title": "PoV Lab Task",
  "description": "JSON-проекция строки tasks. См. specs/02_task_store.md §2.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "project_id",
    "template_id",
    "template_version",
    "stage_gate",
    "status",
    "priority",
    "attempt",
    "escalation_count",
    "version",
    "payload",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "task_id": { "$ref": "#/$defs/Uuid" },
    "project_id": { "$ref": "#/$defs/Uuid" },
    "parent_id": {
      "anyOf": [{ "$ref": "#/$defs/Uuid" }, { "type": "null" }]
    },
    "template_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$" },
    "template_version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "stage_gate": {
      "type": "string",
      "enum": ["intake", "requirements", "architecture", "implementation", "validation", "delivery"]
    },
    "status": {
      "type": "string",
      "enum": ["blocked", "queued", "in_progress", "completed", "failed", "waiting_for_children", "obsolete"]
    },
    "priority": { "type": "integer", "minimum": -1000, "maximum": 1000 },
    "queue_position": { "type": "integer", "minimum": 1 },
    "attempt": { "type": "integer", "minimum": 0 },
    "escalation_count": { "type": "integer", "minimum": 0 },
    "locked_by": { "type": ["string", "null"] },
    "locked_at": { "anyOf": [{ "$ref": "#/$defs/Timestamp" }, { "type": "null" }] },
    "lock_expires_at": { "anyOf": [{ "$ref": "#/$defs/Timestamp" }, { "type": "null" }] },
    "payload": { "type": "object" },
    "summary": { "type": ["string", "null"] },
    "error": {
      "anyOf": [
        { "type": "null" },
        { "$ref": "#/$defs/FailureReason" }
      ]
    },
    "version": { "type": "integer", "minimum": 1 },
    "created_at": { "$ref": "#/$defs/Timestamp" },
    "updated_at": { "$ref": "#/$defs/Timestamp" },
    "started_at": { "anyOf": [{ "$ref": "#/$defs/Timestamp" }, { "type": "null" }] },
    "completed_at": { "anyOf": [{ "$ref": "#/$defs/Timestamp" }, { "type": "null" }] },
    "inputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/TaskInput" }
    },
    "outputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/TaskOutput" }
    },
    "dependencies": {
      "type": "array",
      "items": { "$ref": "#/$defs/TaskDependency" }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "in_progress" } } },
      "then": { "required": ["locked_by", "locked_at", "lock_expires_at"] }
    },
    {
      "if": { "properties": { "status": { "enum": ["completed", "failed"] } } },
      "then": { "required": ["completed_at"] }
    },
    {
      "if": { "properties": { "status": { "const": "failed" } } },
      "then": { "required": ["error"] }
    }
  ],
  "$defs": {
    "Uuid": { "type": "string", "format": "uuid" },
    "Timestamp": { "type": "string", "format": "date-time" },
    "ArtifactRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "artifact_type", "mime_type", "s3_uri", "sha256", "size_bytes", "created_at"],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/Uuid" },
        "artifact_type": { "type": "string" },
        "mime_type": { "type": "string", "pattern": "^[a-z]+/[a-zA-Z0-9.+_-]+$" },
        "s3_uri": { "type": "string", "pattern": "^s3://[a-z0-9.-]+/.+$" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "created_at": { "$ref": "#/$defs/Timestamp" },
        "created_by_task_id": { "anyOf": [{ "$ref": "#/$defs/Uuid" }, { "type": "null" }] }
      }
    },
    "TaskInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_input_id", "task_id", "input_name", "artifact_id", "artifact_type", "source", "resolved_at"],
      "properties": {
        "task_input_id": { "$ref": "#/$defs/Uuid" },
        "task_id": { "$ref": "#/$defs/Uuid" },
        "input_name": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
        "artifact_id": { "$ref": "#/$defs/Uuid" },
        "artifact_type": { "type": "string" },
        "source": { "type": "string", "enum": ["dependency", "semantic", "bootstrap"] },
        "resolved_at": { "$ref": "#/$defs/Timestamp" }
      }
    },
    "TaskOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_output_id", "task_id", "output_name", "artifact_id", "artifact_type", "schema_valid", "produced_at"],
      "properties": {
        "task_output_id": { "$ref": "#/$defs/Uuid" },
        "task_id": { "$ref": "#/$defs/Uuid" },
        "output_name": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
        "artifact_id": { "$ref": "#/$defs/Uuid" },
        "artifact_type": { "type": "string" },
        "schema_valid": { "type": "boolean" },
        "produced_at": { "$ref": "#/$defs/Timestamp" }
      }
    },
    "TaskDependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dep_id", "project_id", "from_task_id", "to_task_id", "kind", "input_name", "created_at"],
      "properties": {
        "dep_id": { "$ref": "#/$defs/Uuid" },
        "project_id": { "$ref": "#/$defs/Uuid" },
        "from_task_id": { "$ref": "#/$defs/Uuid" },
        "to_task_id": { "$ref": "#/$defs/Uuid" },
        "kind": { "type": "string", "enum": ["hard", "soft", "semantic"] },
        "input_name": { "type": "string" },
        "producer_output": { "type": ["string", "null"] },
        "artifact_ref": { "anyOf": [{ "$ref": "#/$defs/Uuid" }, { "type": "null" }] },
        "resolved_at": { "anyOf": [{ "$ref": "#/$defs/Timestamp" }, { "type": "null" }] },
        "created_at": { "$ref": "#/$defs/Timestamp" }
      }
    },
    "FailureReason": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "llm_limit_exceeded",
            "token_budget_exceeded",
            "wall_clock_exceeded",
            "output_validation_failed",
            "hard_input_missing",
            "executor_crashed",
            "dependency_failed",
            "escalation_required",
            "unknown"
          ]
        },
        "message": { "type": "string", "minLength": 1 },
        "details": { "type": "object" },
        "llm_trace_ref": { "anyOf": [{ "$ref": "#/$defs/Uuid" }, { "type": "null" }] }
      }
    }
  }
}
